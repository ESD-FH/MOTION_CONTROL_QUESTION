<?xml version="1.0"?>
<robot name="balance_car_with_collision">

  <material name="blue">   <color rgba="0 0 0.8 1"/> </material>
  <material name="black">  <color rgba="0 0 0 1"/>   </material>
  <material name="white">  <color rgba="1 1 1 1"/>   </material>

  <link name="base_link"/>

  <link name="body_link">
    <visual>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.1 0.11"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.1 0.11"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <mass value="0.334"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.000337" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="base_to_body" type="fixed">
    <parent link="base_link"/>
    <child link="body_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/> <geometry>
        <cylinder length="0.02" radius="0.03375"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.03375"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <mass value="0.178"/>
      <!-- solid cylinder: r=0.03375, L=0.02, m=0.178 -->
      <!-- Izz = 0.5*m*r^2 = 1.013e-4 (about cylinder axis) -->
      <!-- Ixx = Iyy = (1/12)*m*(3*r^2 + L^2) = 5.66e-5 -->
      <inertia ixx="5.66e-05" ixy="0" ixz="0" iyy="5.66e-05" iyz="0" izz="1.013e-04"/>
    </inertial>
  </link>

<joint name="left_wheel_joint" type="revolute">
    <parent link="body_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.06 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="0.8" velocity="16.0" lower="-31415.0" upper="31415.0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.03375"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.03375"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <mass value="0.178"/>
      <inertia ixx="5.66e-05" ixy="0" ixz="0" iyy="5.66e-05" iyz="0" izz="1.013e-04"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="revolute">
    <parent link="body_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.06 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="0.8" velocity="16.0" lower="-31415.0" upper="31415.0"/>
  </joint>

</robot>